# Copy file này thành `.env` rồi điền giá trị THẬT. KHÔNG commit `.env`.

# PayOS (lấy ở dashboard PayOS → Kênh thanh toán)
PAYOS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PAYOS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PAYOS_CHECKSUM_KEY=your_checksum_key_here

# Firebase Admin service account (tải JSON từ Firebase Console →
# Project settings → Service accounts → Generate new private key)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# URL PayOS redirect WebView về sau khi trả xong / hủy (chỉ để đóng WebView).
# Trỏ về subdomain của bạn, path bất kỳ — app sẽ bắt path này để đóng WebView.
RETURN_URL=https://pay.toandz.id.vn/success
CANCEL_URL=https://pay.toandz.id.vn/cancel

# Cổng server local (nginx reverse_proxy trỏ vào cổng này)
PORT=3000
